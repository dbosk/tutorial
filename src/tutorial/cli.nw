\section{Dispatching argparse handlers}

The host application only needs one post-parse hook: if the namespace
contains a tutorial handler, call it and use the returned status code.

<<functions>>=
def run_argparse_command(args: argparse.Namespace) -> int:
    """Dispatch a parsed argparse tutorial command."""

    handler = getattr(args, "tutorial_handler", None)
    if handler is None:
        raise ValueError("No tutorial handler found on parsed arguments.")
    return handler(args)
@


\section{Implementing the argparse leaf commands}

Each leaf command delegates to the same runner layer as Typer.  The only
difference is that argparse commands return integer exit codes instead of
raising [[typer.Exit]].

<<functions>>=
def argparse_list_command(
    args: argparse.Namespace,
    *,
    namespace: str,
    state_root: str | Path | None,
    tutorial_paths: tuple[str | Path, ...],
    shell_runner: Callable[..., object],
) -> int:
    """Implement the argparse ``list`` subcommand."""

    try:
        runner = build_runner(
            namespace=namespace,
            state_root=state_root,
            tutorial_paths=require_tutorial_paths(
                effective_tutorial_paths(
                    tutorial_paths,
                    tuple(args.tutorial_path),
                )
            ),
            shell_runner=shell_runner,
        )
    except (RuntimeError, ValueError) as error:
        print(error)
        return 1
    for tutorial, progress in runner.list_tutorials():
        print(format_progress_line(tutorial.id, progress, tutorial.summary))
    return 0
