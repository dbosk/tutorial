\section{Formatting the review output}

Review is small by design, but it still needs enough structure that a
student can distinguish one step's transcript from the next.

<<functions>>=
def format_review_output(
    tutorial_title: str,
    run_id: str,
    workspace: str,
    transcripts: tuple[StepTranscript, ...],
) -> str:
    """Return formatted review text for saved transcripts."""

    lines = [
        f"Tutorial: {tutorial_title}",
        f"Run: {run_id}",
        f"Workspace: {workspace}",
    ]
    for transcript in transcripts:
        status = "pass" if transcript.passed else "not yet complete"
        lines.extend(
            [
                "",
                f"Step {transcript.step_index + 1}: {transcript.title} [{status}]",
                transcript.transcript.rstrip(),
            ]
        )
    return "\n".join(lines).rstrip() + "\n"
@

<<test functions>>=
def test_format_review_output_groups_transcripts_by_step():
    output = format_review_output(
        "Shell Basics",
        "run-1",
        "/tmp/demo",
        (
            StepTranscript(
                tutorial_id="shell-basics",
                step_index=0,
                title="Inspect the workspace",
                started_at="2026-01-01T00:00:00+00:00",
                ended_at="2026-01-01T00:00:01+00:00",
                exit_status=0,
                transcript="pwd\n/tmp/demo\n",
                passed=True,
            ),
        ),
    )

    assert "Step 1: Inspect the workspace [pass]" in output
    assert "/tmp/demo" in output
