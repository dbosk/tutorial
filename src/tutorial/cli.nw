\section{Building the Typer application}

The standalone CLI and Typer embedding both rely on the same factory.
Using a factory rather than a single global app keeps the namespace and
state-root configuration overridable for tests and host applications.

<<functions>>=
def create_app(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    tutorial_paths: tuple[str | Path, ...] = (),
    shell_runner: Callable[..., object] = run_interactive_shell,
    allow_shell_checks: bool = False,
) -> typer.Typer:
    """Create a Typer application for tutorials."""

    application = typer.Typer(help="Run interactive command-line tutorials.")

    def runner(
        *,
        command_tutorial_paths: tuple[str | Path, ...] = (),
        command_allow_shell_checks: bool = False,
        require_paths: bool = False,
    ) -> TutorialRunner:
        paths = effective_tutorial_paths(tutorial_paths, command_tutorial_paths)
        if require_paths:
            paths = require_tutorial_paths(paths)
        return build_runner(
            namespace=namespace,
            state_root=state_root,
            tutorial_paths=paths,
            shell_runner=shell_runner,
            allow_shell_checks=allow_shell_checks or command_allow_shell_checks,
        )

    @application.command("list")
    def list_command(
        tutorial_path: Annotated[
            list[Path] | None,
            typer.Option(
                "--tutorial-path",
                help=(
                    "Path to a tutorial Markdown file or directory. "
                    "Repeat to add more paths."
                ),
            ),
        ] = None,
    ) -> None:
        """List the loaded tutorials and their saved progress."""

        try:
            tutorial_runner = runner(
                command_tutorial_paths=tuple(tutorial_path or ()),
                require_paths=True,
            )
        except (RuntimeError, ValueError) as error:
            typer.echo(str(error), err=True)
            raise typer.Exit(code=1)

        for tutorial, progress in tutorial_runner.list_tutorials():
            typer.echo(
                format_progress_line(tutorial.id, progress, tutorial.summary)
            )

    @application.command("run")
    def run_command(
        tutorial_id: str,
        tutorial_path: Annotated[
            list[Path] | None,
            typer.Option(
                "--tutorial-path",
                help=(
                    "Path to a tutorial Markdown file or directory. "
                    "Repeat to add more paths."
                ),
            ),
        ] = None,
        restart: Annotated[
            bool,
            typer.Option(
                "--restart",
                help="Start a fresh run instead of resuming saved progress.",
            ),
        ] = False,
        allow_shell_checks_flag: Annotated[
            bool,
            typer.Option(
                "--allow-shell-checks",
                help=(
                    "Trust tutorial-authored shell validation commands for "
                    "this run."
                ),
            ),
        ] = False,
    ) -> None:
        """Run or resume one tutorial."""

        console = Console()

        def prompt_for_input(prompt: str) -> str:
            return typer.prompt(prompt)

        def before_step(tutorial, step_index, step, run) -> None:
            render_step_prompt(
                console,
                tutorial.title,
                step_index + 1,
                len(tutorial.steps),
                step.title,
                step.instructions,
                run.workspace,
            )

        try:
            tutorial_runner = runner(
                command_tutorial_paths=tuple(tutorial_path or ()),
                command_allow_shell_checks=allow_shell_checks_flag,
                require_paths=True,
            )
            result = run_tutorial_with_menu(
                tutorial_runner,
                tutorial_id,
                restart=restart,
                before_step=before_step,
                console=console,
                prompt_for_input=prompt_for_input,
            )
        except KeyError as error:
            raise typer.BadParameter(str(error), param_hint="tutorial_id")
        except (RuntimeError, ValueError) as error:
            typer.echo(str(error), err=True)
            raise typer.Exit(code=1)

        if result.blocked_step is not None:
            raise typer.Exit(code=1)

        emit_run_summary(result)

    @application.command("review")
    def review_command(
        tutorial_id: str,
        step: Annotated[
            int | None,
            typer.Option(
                "--step",
                min=1,
                help="Review only the latest transcript for one step.",
            ),
        ] = None,
        run_id: Annotated[
            str | None,
            typer.Option(
                "--run-id",
                help="Review a specific saved run instead of the latest one.",
            ),
        ] = None,
    ) -> None:
        """Review saved transcripts for one tutorial."""

        console = Console()
        try:
            tutorial_runner = runner()
            tutorial, run, transcripts = tutorial_runner.review(
                tutorial_id,
                step_number=step,
                run_id=run_id,
            )
        except (KeyError, IndexError, ValueError) as error:
            typer.echo(str(error), err=True)
            raise typer.Exit(code=1)

        render_review_output(
            console,
            tutorial.title,
            run.run_id,
            run.workspace,
            transcripts,
        )

    return application
@

