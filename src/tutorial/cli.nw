\section{Formatting step prompts}

Each step opens a fresh shell, so the CLI must print the instructions
before the shell starts.  We author that student-facing text as Markdown
and render it with Rich [[Markdown]] so paragraphs and inline commands
read cleanly in an ordinary terminal.

A little vertical space around the body matters too.  Without it, the
workspace line, the instructions, and the exit reminder blur together
into one dense block of text.

<<functions>>=
def render_step_prompt(
    console: Console,
    tutorial_title: str,
    step_number: int,
    total_steps: int,
    step_title: str,
    instructions: str,
    workspace: str,
) -> None:
    """Render the prompt shown before one interactive step."""

    console.print()
    console.print(tutorial_title, style="bold")
    console.print(
        f"Step {step_number}/{total_steps}: {step_title}",
        style="bold",
    )
    console.print(f"Workspace: {workspace}", style="dim")
    console.print()
    console.print(Markdown(instructions))
    console.print()
    console.print(
        "Exit the shell when you want the tutorial to validate the step.",
        style="dim",
    )
    console.print()
@

<<test functions>>=
def test_render_step_prompt_uses_markdown_and_spacing():
    buffer = StringIO()
    console = Console(
        file=buffer,
        width=80,
        force_terminal=False,
        color_system=None,
    )

    render_step_prompt(
        console,
        "Shell Basics",
        1,
        3,
        "Inspect the workspace",
        "Run `pwd` and `ls`.\n\nThis shows where the tutorial stores its work.",
        "/tmp/demo",
    )

    output = buffer.getvalue()
    assert "Step 1/3: Inspect the workspace" in output
    assert "Workspace: /tmp/demo\n\n" in output
    assert "Run pwd and ls." in output
    assert "This shows where the tutorial stores its work." in output
    assert "\n\nExit the shell when you want" in output
    assert "`pwd`" not in output
