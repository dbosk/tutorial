\section{Summarising a run for the terminal}

The CLI should give concise feedback after the runner returns.  We keep
that logic separate from the command function so the argparse wrapper can
reuse it.

<<functions>>=
def emit_run_summary(result: RunResult) -> None:
    """Print a concise summary for a completed run command."""

    if result.already_finished:
        typer.echo(
            "Tutorial already completed. Use --restart to begin a fresh run."
        )
        return

    if result.blocked_step is not None:
        typer.echo(
            f"Step not complete yet: {result.blocked_step.title}",
            err=True,
        )
        if result.blocked_step.hint:
            render_hint(Console(stderr=True), result.blocked_step.hint)
        raise typer.Exit(code=1)

    typer.echo(
        f"Completed {result.tutorial.id}. Review it with "
        f"`tutorial review {result.tutorial.id}`."
    )
