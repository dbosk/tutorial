\section{Embedding in an argparse application}

Argparse composition needs a little more plumbing because there is no
native equivalent of Typer's sub-app mounting.  We therefore create the
subparser tree and store a callable on each leaf parser.

<<functions>>=
def add_argparse_subcommand(
    subparsers: argparse._SubParsersAction,
    *,
    name: str = "tutorial",
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    tutorial_paths: tuple[str | Path, ...] = (),
    shell_runner: Callable[..., object] = run_interactive_shell,
    editor_runner: Callable[..., object] = run_editor,
    allow_shell_checks: bool = False,
) -> argparse.ArgumentParser:
    """Attach the tutorial CLI as an argparse subcommand tree."""

    parser = subparsers.add_parser(name, help="Run interactive tutorials")
    tutorial_subparsers = parser.add_subparsers(dest="tutorial_command")
    tutorial_subparsers.required = True

    list_parser = tutorial_subparsers.add_parser("list", help="List tutorials")
    list_parser.add_argument(
        "--tutorial-path",
        action="append",
        default=[],
        help="Path to a tutorial Markdown file or directory. Repeat to add more paths.",
    )
    list_parser.set_defaults(
        tutorial_handler=lambda args: argparse_list_command(
            args,
            namespace=namespace,
            state_root=state_root,
            tutorial_paths=embedded_tutorial_paths(tutorial_paths),
            shell_runner=shell_runner,
            editor_runner=editor_runner,
        )
    )

    review_parser = tutorial_subparsers.add_parser(
        "review",
        help="Review saved transcripts",
    )
    review_parser.add_argument("tutorial_id")
    review_parser.add_argument("--step", type=int)
    review_parser.add_argument("--run-id")
    review_parser.set_defaults(
        tutorial_handler=lambda args: argparse_review_command(
            args,
            namespace=namespace,
            state_root=state_root,
            tutorial_paths=embedded_tutorial_paths(tutorial_paths),
            shell_runner=shell_runner,
            editor_runner=editor_runner,
        )
    )

    run_parser = tutorial_subparsers.add_parser("run", help="Run a tutorial")
    run_parser.add_argument(
        "--tutorial-path",
        action="append",
        default=[],
        help="Path to a tutorial Markdown file or directory. Repeat to add more paths.",
    )
    run_parser.add_argument(
        "--allow-shell-checks",
        action="store_true",
        help="Trust tutorial-authored shell validation commands for this run.",
    )
    run_parser.add_argument("tutorial_id")
    run_parser.add_argument("--restart", action="store_true")
    run_parser.set_defaults(
        tutorial_handler=lambda args: argparse_run_command(
            args,
            namespace=namespace,
            state_root=state_root,
            tutorial_paths=embedded_tutorial_paths(tutorial_paths),
            shell_runner=shell_runner,
            editor_runner=editor_runner,
            allow_shell_checks=allow_shell_checks,
        )
    )
    return parser
