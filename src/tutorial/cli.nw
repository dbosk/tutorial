\section{Choosing what to do after a failed step}

The runner already persists failed attempts and leaves the tutorial at the
same unfinished step.  That means the CLI can offer a small menu after a
failure without adding any new resume state of its own.

We accept both the full phrases and short aliases.  The full phrases keep
the prompt readable for students, while the aliases make repeated retries
quick.

<<functions>>=
def normalise_blocked_step_action(choice: str) -> str | None:
    """Return the canonical failed-step action for ``choice``."""

    normalised = " ".join(choice.strip().lower().split())
    return {
        "r": "read_again",
        "read": "read_again",
        "read again": "read_again",
        "t": "try_again",
        "try": "try_again",
        "try again": "try_again",
        "retry": "try_again",
        "h": "hint",
        "hint": "hint",
        "e": "exit",
        "exit": "exit",
    }.get(normalised)
@

Let's verify that both the readable phrases and the short aliases map to
the same actions.

<<test functions>>=
def test_normalise_blocked_step_action_accepts_long_and_short_forms():
    assert normalise_blocked_step_action("read again") == "read_again"
    assert normalise_blocked_step_action("r") == "read_again"
    assert normalise_blocked_step_action("try again") == "try_again"
    assert normalise_blocked_step_action("retry") == "try_again"
    assert normalise_blocked_step_action("h") == "hint"
    assert normalise_blocked_step_action("exit") == "exit"
    assert normalise_blocked_step_action("nope") is None
@


\section{Prompting until the user chooses a valid action}

The CLI should not throw the student out of the tutorial flow because of a
typo at the menu prompt.  We therefore keep asking until the answer maps
to one of the supported actions.

<<functions>>=
def prompt_for_blocked_step_action(
    console: Console,
    prompt_for_input: Callable[[str], str],
) -> str:
    """Ask until the user chooses a supported failed-step action."""

    prompt = "Choose [read again / try again / hint / exit]"
    while True:
        action = normalise_blocked_step_action(prompt_for_input(prompt))
        if action is not None:
            return action

        console.print(
            "Choose one of: read again, try again, hint, exit.",
            style="dim",
        )
@

<<test functions>>=
def test_prompt_for_blocked_step_action_reprompts_after_invalid_input():
    buffer = StringIO()
    console = Console(
        file=buffer,
        width=80,
        force_terminal=False,
        color_system=None,
    )
    answers = iter(["maybe", "hint"])

    action = prompt_for_blocked_step_action(
        console,
        lambda prompt: next(answers),
    )

    assert action == "hint"
    assert "Choose one of: read again, try again, hint, exit." in buffer.getvalue()
@


\section{Handling a blocked step}

The menu itself stays in the CLI layer because the runner already knows
how to resume the same unfinished step on the next call.  The CLI only
needs to decide whether to show the instructions again, reveal the hint,
try the step again, or stop.

<<functions>>=
def blocked_step_number(result: RunResult) -> int:
    """Return the 1-based number of the blocked step."""

    if result.blocked_transcript is not None:
        return result.blocked_transcript.step_index + 1
    return result.progress.completed_steps + 1
@

<<functions>>=
def handle_blocked_step(
    result: RunResult,
    *,
    console: Console,
    prompt_for_input: Callable[[str], str],
) -> str:
    """Offer follow-up actions for a blocked tutorial step."""

    if result.blocked_step is None:
        raise ValueError("Blocked-step handling requires a blocked step.")

    console.print()
    console.print(f"Step not complete yet: {result.blocked_step.title}", style="bold")

    while True:
        action = prompt_for_blocked_step_action(console, prompt_for_input)
        if action == "read_again":
            render_step_prompt(
                console,
                result.tutorial.title,
                blocked_step_number(result),
                len(result.tutorial.steps),
                result.blocked_step.title,
                result.blocked_step.instructions,
                result.run.workspace,
            )
            continue

        if action == "hint":
            if result.blocked_step.hint:
                render_hint(console, result.blocked_step.hint)
            else:
                console.print()
                console.print("No hint available for this step.", style="dim")
                console.print()
            continue

        return action
@

