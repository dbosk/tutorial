\section{Running until the tutorial completes or the user exits}

One failed step should not force the student to restart the whole command.
Because the runner persists each attempt immediately, the CLI can call it
again after a [[try again]] choice and let the runner resume exactly where
it left off.

<<functions>>=
def run_tutorial_with_menu(
    tutorial_runner: TutorialRunner,
    tutorial_id: str,
    *,
    restart: bool,
    before_step: Callable[..., None],
    console: Console,
    prompt_for_input: Callable[[str], str],
) -> RunResult:
    """Run a tutorial command with a failed-step action menu."""

    pending_restart = restart
    while True:
        result = tutorial_runner.run(
            tutorial_id,
            restart=pending_restart,
            before_step=before_step,
        )
        pending_restart = False
        if result.blocked_step is None:
            return result

        action = handle_blocked_step(
            result,
            console=console,
            prompt_for_input=prompt_for_input,
        )
        if action == "exit":
            return result
@

