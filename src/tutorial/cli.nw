<<functions>>=
def require_tutorial_paths(
    tutorial_paths: tuple[str | Path, ...],
) -> tuple[str | Path, ...]:
    """Require an explicit tutorial path for commands that load tutorials."""

    if tutorial_paths:
        return tutorial_paths
    raise RuntimeError("No tutorial paths configured. Pass --tutorial-path.")
