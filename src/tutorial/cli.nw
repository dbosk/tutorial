def test_review_command_shows_saved_transcript(tmp_path):
    store = StateStore(tmp_path)
    run = store.start_run("shell-basics")
    run.transcripts.append(
        StepTranscript(
            tutorial_id="shell-basics",
            step_index=0,
            title="Inspect the workspace",
            started_at="2026-01-01T00:00:00+00:00",
            ended_at="2026-01-01T00:00:01+00:00",
            exit_status=0,
            transcript="pwd\n/tmp/demo\n",
            passed=True,
        )
    )
    store.store_run(run)

    runner = CliRunner()
    result = runner.invoke(
        create_app(state_root=tmp_path),
        ["review", "shell-basics"],
    )

    assert result.exit_code == 0
    assert "Inspect the workspace" in result.stdout
