\section{Embedding in an argparse application}

Argparse composition needs a little more plumbing because there is no
native equivalent of Typer's sub-app mounting.  We therefore create the
subparser tree and store a callable on each leaf parser.

<<functions>>=
def add_argparse_subcommand(
    subparsers: argparse._SubParsersAction,
    *,
    name: str = "tutorial",
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    shell_runner: Callable[..., object] = run_interactive_shell,
) -> argparse.ArgumentParser:
    """Attach the tutorial CLI as an argparse subcommand tree."""

    parser = subparsers.add_parser(name, help="Run interactive tutorials")
    tutorial_subparsers = parser.add_subparsers(dest="tutorial_command")
    tutorial_subparsers.required = True

    list_parser = tutorial_subparsers.add_parser("list", help="List tutorials")
    list_parser.set_defaults(
        tutorial_handler=lambda args: argparse_list_command(
            namespace=namespace,
            state_root=state_root,
            shell_runner=shell_runner,
        )
    )

    review_parser = tutorial_subparsers.add_parser(
        "review",
        help="Review saved transcripts",
    )
    review_parser.add_argument("tutorial_id")
    review_parser.add_argument("--step", type=int)
    review_parser.add_argument("--run-id")
    review_parser.set_defaults(
        tutorial_handler=lambda args: argparse_review_command(
            args,
            namespace=namespace,
            state_root=state_root,
            shell_runner=shell_runner,
        )
    )

    run_parser = tutorial_subparsers.add_parser("run", help="Run a tutorial")
    run_parser.add_argument("tutorial_id")
    run_parser.add_argument("--restart", action="store_true")
    run_parser.set_defaults(
        tutorial_handler=lambda args: argparse_run_command(
            args,
            namespace=namespace,
            state_root=state_root,
            shell_runner=shell_runner,
        )
    )
    return parser
@

<<test functions>>=
def test_add_argparse_subcommand_creates_dispatchable_handler(tmp_path, capsys):
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command")
    subparsers.required = True
    add_argparse_subcommand(subparsers, state_root=tmp_path)

    args = parser.parse_args(["tutorial", "list"])
    exit_code = run_argparse_command(args)
    captured = capsys.readouterr()

    assert exit_code == 0
    assert "shell-basics" in captured.out
@


\section{Dispatching argparse handlers}

The host application only needs one post-parse hook: if the namespace
contains a tutorial handler, call it and use the returned status code.

<<functions>>=
def run_argparse_command(args: argparse.Namespace) -> int:
    """Dispatch a parsed argparse tutorial command."""

    handler = getattr(args, "tutorial_handler", None)
    if handler is None:
        raise ValueError("No tutorial handler found on parsed arguments.")
    return handler(args)
@


\section{Implementing the argparse leaf commands}

Each leaf command delegates to the same runner layer as Typer.  The only
difference is that argparse commands return integer exit codes instead of
raising [[typer.Exit]].

<<functions>>=
def argparse_list_command(
    *,
    namespace: str,
    state_root: str | Path | None,
    shell_runner: Callable[..., object],
) -> int:
    """Implement the argparse ``list`` subcommand."""

    runner = build_runner(
        namespace=namespace,
        state_root=state_root,
        shell_runner=shell_runner,
    )
    for tutorial, progress in runner.list_tutorials():
        print(format_progress_line(tutorial.id, progress, tutorial.summary))
    return 0
@

<<functions>>=
def argparse_review_command(
    args: argparse.Namespace,
    *,
    namespace: str,
    state_root: str | Path | None,
    shell_runner: Callable[..., object],
) -> int:
    """Implement the argparse ``review`` subcommand."""

    runner = build_runner(
        namespace=namespace,
        state_root=state_root,
        shell_runner=shell_runner,
    )
    try:
        tutorial, run, transcripts = runner.review(
            args.tutorial_id,
            step_number=args.step,
            run_id=args.run_id,
        )
    except (KeyError, IndexError) as error:
        print(error)
        return 1

    print(
        format_review_output(
            tutorial.title,
            run.run_id,
            run.workspace,
            transcripts,
        ),
        end="",
    )
    return 0
@

<<functions>>=
def argparse_run_command(
    args: argparse.Namespace,
    *,
    namespace: str,
    state_root: str | Path | None,
    shell_runner: Callable[..., object],
) -> int:
    """Implement the argparse ``run`` subcommand."""

    tutorial_runner = build_runner(
        namespace=namespace,
        state_root=state_root,
        shell_runner=shell_runner,
    )

    def before_step(tutorial, step_index, step, run) -> None:
        print(
            format_step_prompt(
                tutorial.title,
                step_index + 1,
                len(tutorial.steps),
                step.title,
                step.instructions,
                run.workspace,
            )
        )

    try:
        result = tutorial_runner.run(
            args.tutorial_id,
            restart=args.restart,
            before_step=before_step,
        )
    except (KeyError, RuntimeError) as error:
        print(error)
        return 1

    try:
        emit_run_summary(result)
    except typer.Exit as error:
        return error.exit_code
    return 0
@
