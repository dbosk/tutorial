        "shell-basics",
        ProgressState(
            tutorial_id="shell-basics",
            total_steps=3,
            completed_steps=1,
            finished=False,
        ),
        "A short summary.",
    )

    assert "1/3 complete" in line
    assert "A short summary." in line
