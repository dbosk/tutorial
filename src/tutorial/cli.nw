    result = runner.invoke(
        create_app(state_root=tmp_path / "state", shell_runner=scripted_runner),
        [
            "run",
            "--tutorial-path",
            str(tutorial_path),
            "--allow-shell-checks",
            "shell-basics",
        ],
        input="try again\n",
    )

    assert result.exit_code == 0
    assert "Step not complete yet: Inspect the workspace" in result.stdout
    assert "Completed shell-basics" in result.stdout
