\section{Embedding in another Typer application}

Typer already has a clean composition API, so the helper only needs to
build a configured sub-application and register it under the requested
name.

<<functions>>=
def add_typer_subcommand(
    parent_app: typer.Typer,
    *,
    name: str = "tutorial",
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    shell_runner: Callable[..., object] = run_interactive_shell,
) -> typer.Typer:
    """Attach the tutorial CLI as a Typer subcommand."""

    child_app = create_app(
        namespace=namespace,
        state_root=state_root,
        shell_runner=shell_runner,
    )
    parent_app.add_typer(child_app, name=name)
    return child_app
@

<<test functions>>=
def test_add_typer_subcommand_registers_tutorial_namespace(tmp_path):
    parent = typer.Typer()
    add_typer_subcommand(parent, state_root=tmp_path)

    runner = CliRunner()
    result = runner.invoke(parent, ["tutorial", "list"])

    assert result.exit_code == 0
    assert "shell-basics" in result.stdout
