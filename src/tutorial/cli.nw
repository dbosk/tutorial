\section{Formatting step prompts}

Each step opens a fresh shell, so the CLI must print the instructions
before the shell starts.  The text also reminds the student that leaving
the shell returns control to the tutorial runner.

<<functions>>=
def format_step_prompt(
    tutorial_title: str,
    step_number: int,
    total_steps: int,
    step_title: str,
    instructions: str,
    workspace: str,
) -> str:
    """Return the prompt shown before one interactive step."""

    return (
        f"{tutorial_title}\n"
        f"Step {step_number}/{total_steps}: {step_title}\n"
        f"Workspace: {workspace}\n"
        f"{instructions}\n"
        "Exit the shell when you want the tutorial to validate the step."
    )
@

<<test functions>>=
def test_format_step_prompt_mentions_workspace_and_exit():
    prompt = format_step_prompt(
        "Shell Basics",
        1,
        3,
        "Inspect the workspace",
        "Run pwd and ls.",
        "/tmp/demo",
    )

    assert "Step 1/3" in prompt
    assert "Exit the shell" in prompt
