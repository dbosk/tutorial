\section{Parsing the YAML front matter}

Each tutorial file starts with a front matter block delimited by
[[---]].  We separate that block from the Markdown body before doing any
further parsing so the step splitter never has to know about front matter.

<<functions>>=
def split_yaml_front_matter(text: str) -> tuple[str, str]:
    """Return ``(front_matter, body)`` for one tutorial file."""

    lines = text.splitlines(keepends=True)
    if not lines or lines[0].strip() != "---":
        raise ValueError(
            "Tutorial files must start with YAML front matter delimited by ---."
        )

    for index, line in enumerate(lines[1:], start=1):
        if line.strip() == "---":
            return "".join(lines[1:index]), "".join(lines[index + 1 :])

    raise ValueError("Tutorial front matter is missing its closing ---.")
@

<<test functions>>=
def test_split_yaml_front_matter_requires_delimiters():
    with pytest.raises(ValueError, match="YAML front matter"):
        split_yaml_front_matter("# Step\n\nDo it.\n")
