\section{Resolving explicit tutorial paths}

Packaged built-ins are only one source of tutorials.  Callers may still
provide extra Markdown files or directories explicitly, and a directory is
most useful when it expands to every tutorial file below it.

<<functions>>=
def resolve_tutorial_files(
    tutorial_paths: tuple[str | Path, ...],
) -> tuple[Path, ...]:
    """Return the Markdown tutorial files addressed by ``tutorial_paths``."""

    if not tutorial_paths:
        raise ValueError("No tutorial paths configured. Pass --tutorial-path.")

    files = []
    seen = set()
    for raw_path in tutorial_paths:
        path = Path(raw_path)
        if not path.exists():
            raise ValueError(f"Tutorial path {path} does not exist.")

        if path.is_dir():
            candidates = sorted(
                item for item in path.rglob("*.md") if item.is_file()
            )
            if not candidates:
                raise ValueError(
                    f"Tutorial path {path} does not contain any .md files."
                )
        else:
            if path.suffix.lower() != ".md":
                raise ValueError(
                    f"Tutorial file {path} must use the .md extension."
                )
            candidates = [path]

        for candidate in candidates:
            resolved = candidate.resolve()
            if resolved in seen:
                continue
            seen.add(resolved)
            files.append(resolved)

    return tuple(files)
