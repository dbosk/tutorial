\section{Fingerprinting one tutorial file}

Resuming an unfinished run only makes sense if the tutorial definition is
still the same as when the run began.  A file digest gives the runner a
small, stable identity check.

<<functions>>=
def build_source_digest(text: str) -> str:
    """Return a stable digest for one tutorial source file."""

    return hashlib.sha256(text.encode("utf-8")).hexdigest()
@


\section{Validating small YAML values}

The YAML schema is intentionally small, but the loader still needs a few
helpers so that type errors produce clear, local messages.

<<functions>>=
def reject_unknown_keys(metadata: dict, allowed: set[str], context: str) -> None:
    """Reject keys that are not part of the supported schema."""

    unknown = sorted(key for key in metadata if key not in allowed)
    if unknown:
        names = ", ".join(repr(key) for key in unknown)
        raise ValueError(f"{context} contains unsupported keys: {names}.")
@

<<functions>>=
def require_string(metadata: dict, key: str, context: str) -> str:
    """Return the non-empty string field ``key`` from ``metadata``."""

    value = metadata.get(key)
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"{context} requires a non-empty string field {key!r}.")
    return value.strip()
@

<<functions>>=
def optional_string(value: object, context: str) -> str | None:
    """Return ``value`` as a string or [[None]]."""

    if value is None:
        return None
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"{context} must be a non-empty string when set.")
    return value.strip()
@

<<functions>>=
def string_tuple(value: object, context: str) -> tuple[str, ...]:
    """Return ``value`` as a tuple of strings."""

    if value is None:
        return ()
    if not isinstance(value, list):
        raise ValueError(f"{context} must be a YAML list of strings.")

    items = []
    for item in value:
        if not isinstance(item, str) or not item:
            raise ValueError(f"{context} must only contain non-empty strings.")
        items.append(item)
    return tuple(items)
@


