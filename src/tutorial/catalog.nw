\section{Validating small YAML values}

The YAML schema is intentionally small, but the loader still needs a few
helpers so that type errors produce clear, local messages.

<<functions>>=
def reject_unknown_keys(metadata: dict, allowed: set[str], context: str) -> None:
    """Reject keys that are not part of the supported schema."""

    unknown = sorted(key for key in metadata if key not in allowed)
    if unknown:
        names = ", ".join(repr(key) for key in unknown)
        raise ValueError(f"{context} contains unsupported keys: {names}.")
@

<<functions>>=
def require_string(metadata: dict, key: str, context: str) -> str:
    """Return the non-empty string field ``key`` from ``metadata``."""

    value = metadata.get(key)
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"{context} requires a non-empty string field {key!r}.")
    return value.strip()
@

<<functions>>=
def optional_string(value: object, context: str) -> str | None:
    """Return ``value`` as a string or [[None]]."""

    if value is None:
        return None
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"{context} must be a non-empty string when set.")
    return value.strip()
@

Question steps use literal options, while free-text input steps reuse the
existing recorded-text matcher schema for their answers.  Keeping those
helpers separate lets the loader reject mismatched combinations early.

<<functions>>=
def option_tuple(value: object, context: str) -> tuple[str, ...]:
    """Return ``value`` as a tuple of option strings."""

    if value is None:
        return ()
    if not isinstance(value, list):
        raise ValueError(f"{context} must be a YAML list of strings.")

    return tuple(require_non_empty_string(item, f"{context} item") for item in value)
@

<<functions>>=
def require_non_empty_string(value: object, context: str) -> str:
    """Return ``value`` as one non-empty string."""

    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"{context} must be a non-empty string.")
    return value.strip()
@

<<functions>>=
def literal_answer_tuple(value: object, context: str) -> tuple[str, ...]:
    """Return ``value`` as a tuple of literal answer strings."""

    if value is None:
        return ()
    if not isinstance(value, list):
        raise ValueError(f"{context} must be a YAML list of strings.")

    return tuple(require_non_empty_string(item, f"{context} item") for item in value)
@

<<functions>>=
def step_answers(
    metadata: dict,
    title: str,
    kind: str | None,
) -> tuple[str | TextMatch, ...]:
    """Return the parsed answers tuple for one step."""

    context = f"Step {title!r} answers"
    if kind == "input":
        return text_match_tuple(metadata.get("answers"), context)
    if kind in {"single_select", "multi_select"}:
        return literal_answer_tuple(metadata.get("answers"), context)
    return ()
@

We validate missing-[[kind]] errors from the authored metadata keys rather
than only from the parsed tuples.  That way a stray [[answers:]] field is
still rejected even though the loader does not yet know how to interpret it.

<<functions>>=
def validate_step_shape(
    title: str,
    *,
    kind: str | None,
    has_options: bool,
    has_answers: bool,
    options: tuple[str, ...],
    answers: tuple[str | TextMatch, ...],
    edit_file: str | None,
) -> None:
    """Reject unsupported step metadata combinations."""

    context = f"Step {title!r}"
    allowed_kinds = {None, "input", "multi_select", "single_select"}
    if kind not in allowed_kinds:
        raise ValueError(
            f"{context} kind must be 'input', 'single_select', or "
            "'multi_select'."
        )
    if kind is not None and edit_file is not None:
        raise ValueError(f"{context} cannot combine kind with edit_file.")
    if kind is None:
        if has_options:
            raise ValueError(f"{context} options require kind.")
        if has_answers:
            raise ValueError(f"{context} answers require kind.")
        return

    if kind == "input":
        if options:
            raise ValueError(f"{context} input steps do not support options.")
        if not answers:
            raise ValueError(f"{context} input steps require answers.")
        return

    if not options:
        raise ValueError(f"{context} {kind} steps require options.")
    if not answers:
        raise ValueError(f"{context} {kind} steps require answers.")

    unknown_answers = [answer for answer in answers if answer not in options]
    if unknown_answers:
        names = ", ".join(repr(answer) for answer in unknown_answers)
        raise ValueError(f"{context} answers must be drawn from options: {names}.")
    if kind == "single_select" and len(answers) != 1:
        raise ValueError(f"{context} single_select steps require exactly one answer.")
    if kind == "multi_select" and len(set(answers)) != len(answers):
        raise ValueError(f"{context} multi_select answers must not repeat options.")
@

<<functions>>=
def text_match(value: object, context: str) -> TextMatch:
    """Return one recorded-text match from tutorial metadata."""

    if isinstance(value, str):
        if not value:
            raise ValueError(f"{context} must only contain non-empty strings.")
        return TextMatch(value)

    if not isinstance(value, dict):
        raise ValueError(
            f"{context} items must be strings or mappings with mode/pattern."
        )

    reject_unknown_keys(value, {"mode", "pattern"}, context)
    mode = require_string(value, "mode", context)
    pattern = require_string(value, "pattern", context)
    if mode not in {"contains", "regex"}:
        raise ValueError(f"{context} mode must be 'contains' or 'regex'.")
    return TextMatch(pattern=pattern, mode=mode)
@

<<functions>>=
def text_match_tuple(value: object, context: str) -> tuple[TextMatch, ...]:
    """Return ``value`` as a tuple of recorded-text matches."""

    if value is None:
        return ()
    if not isinstance(value, list):
        raise ValueError(
            f"{context} must be a YAML list of strings or match mappings."
        )

    return tuple(
        text_match(item, f"{context} item")
        for item in value
    )
@


