\section{Looking up one tutorial}

The runner needs a direct lookup helper so the CLI can fail early with a
useful message when the user asks for an unknown tutorial.

<<functions>>=
def get_tutorial(tutorial_id: str) -> Tutorial:
    """Return the built-in tutorial with the given ID."""

    for tutorial in BUILTIN_TUTORIALS:
        if tutorial.id == tutorial_id:
            return tutorial

    available = ", ".join(tutorial.id for tutorial in BUILTIN_TUTORIALS)
    raise KeyError(
        f"Unknown tutorial {tutorial_id!r}. Available tutorials: {available}"
    )
@

<<test functions>>=
def test_get_tutorial_returns_requested_tutorial():
    tutorial = get_tutorial("shell-basics")

    assert tutorial.title == "Shell Basics"
    assert len(tutorial.steps) == 3


def test_get_tutorial_rejects_unknown_ids():
    with pytest.raises(KeyError, match="Available tutorials"):
        get_tutorial("missing")
@
