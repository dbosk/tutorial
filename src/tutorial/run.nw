def list_tutorials(self) -> tuple[tuple[Tutorial, ProgressState], ...]:
    """Return all loaded tutorials paired with saved progress."""

    entries = []
    for tutorial in self.catalog.get_tutorials():
        run = self.store.latest_run(tutorial.id)
        entries.append((tutorial, self.store.progress_for(tutorial, run)))
    return tuple(entries)
