<<test functions>>=
def test_runner_completes_shell_basics_with_scripted_shell(tmp_path):
    store = StateStore(tmp_path)
    commands = iter(
        [
            "pwd\nls\n",
            "printf 'tutorial\\n' > notes.txt\n",
            "cat notes.txt\n",
        ]
    )

    def scripted_runner(*, workspace):
        return run_scripted_shell(next(commands), workspace=workspace)

    runner = TutorialRunner(store, shell_runner=scripted_runner)
    result = runner.run("shell-basics")

    assert result.progress.finished is True
    assert result.executed_steps == 3
    assert len(store.latest_run("shell-basics").transcripts) == 3


def test_runner_resumes_unfinished_run(tmp_path):
    store = StateStore(tmp_path)
    first_commands = iter(["pwd\n"])

    def first_runner(*, workspace):
        return run_scripted_shell(next(first_commands), workspace=workspace)

    runner = TutorialRunner(store, shell_runner=first_runner)
    first_result = runner.run("shell-basics")

    assert first_result.progress.completed_steps == 0
    previous_run_id = first_result.run.run_id

    second_commands = iter(
        [
            "pwd\nls\n",
            "printf 'tutorial\\n' > notes.txt\n",
            "cat notes.txt\n",
        ]
    )

    def second_runner(*, workspace):
        return run_scripted_shell(next(second_commands), workspace=workspace)

    resumed = TutorialRunner(store, shell_runner=second_runner).run("shell-basics")

    assert resumed.run.run_id == previous_run_id
    assert resumed.progress.finished is True


def test_runner_restart_creates_new_run(tmp_path):
    store = StateStore(tmp_path)
    commands = iter(["pwd\n"])

    def first_runner(*, workspace):
        return run_scripted_shell(next(commands), workspace=workspace)

    first = TutorialRunner(store, shell_runner=first_runner).run("shell-basics")

    restart_commands = iter(["pwd\n"])

    def restart_runner(*, workspace):
        return run_scripted_shell(next(restart_commands), workspace=workspace)

    restarted = TutorialRunner(store, shell_runner=restart_runner).run(
        "shell-basics",
        restart=True,
    )

    assert restarted.restarted is True
    assert restarted.run.run_id != first.run.run_id
