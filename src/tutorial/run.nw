\subsection{Selecting which run to use}

Separating this policy into its own method keeps the main run loop about
step execution rather than resume bookkeeping.

<<tutorial runner methods>>=
def select_run(
    self,
    tutorial: Tutorial,
    *,
    restart: bool = False,
) -> tuple[TutorialRun, bool, bool]:
    """Return ``(run, restarted, already_finished)`` for ``tutorial``."""

    latest = self.store.latest_run(tutorial.id)
    if latest is None:
        return self.store.start_run(tutorial.id), False, False

    progress = self.store.progress_for(tutorial, latest)
    if restart:
        return self.store.start_run(tutorial.id), True, False

    if progress.finished:
        return latest, False, True

    return latest, False, False
@

<<test functions>>=
def test_select_run_reuses_latest_incomplete_run(tmp_path):
    store = StateStore(tmp_path)
    tutorial = get_tutorial("shell-basics")
    run = store.start_run(tutorial.id)
    runner = TutorialRunner(store)

    selected, restarted, already_finished = runner.select_run(tutorial)

    assert selected.run_id == run.run_id
    assert restarted is False
    assert already_finished is False
