\section{Turning shell output into a transcript record}

The runner stores shell sessions as step transcripts so the state layer
can persist them without knowing anything about validation policy.

<<functions>>=
def build_step_transcript(
    *,
    tutorial_id: str,
    step_index: int,
    step: TutorialStep,
    shell_result: ShellResult,
    passed: bool,
) -> StepTranscript:
    """Convert a shell result into a persisted step transcript."""

    return StepTranscript(
        tutorial_id=tutorial_id,
        step_index=step_index,
        title=step.title,
        started_at=shell_result.started_at,
        ended_at=shell_result.ended_at,
        exit_status=shell_result.exit_status,
        transcript=shell_result.transcript,
        passed=passed,
    )
@

