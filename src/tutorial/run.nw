\section{Validating one step}

Validation combines transcript-based checks and shell-state checks.
Neither mechanism is enough on its own for the first release, but the two
small checks together cover the common tutorial patterns well.

<<functions>>=
def validate_step(
    step: TutorialStep,
    transcript: str,
    workspace: str | Path,
) -> bool:
    """Return whether ``step`` passed in ``workspace``."""

    patterns_ok = transcript_matches_patterns(transcript, step.required_patterns)
    command_ok = check_command_passes(step.check_command, workspace)
    return patterns_ok and command_ok
@

<<test functions>>=
def test_validate_step_requires_both_transcript_and_file_state(tmp_path):
    step = TutorialStep(
        title="Create note",
        instructions="Do it.",
        required_patterns=("cat notes.txt",),
        check_command="test -f notes.txt",
    )
    (tmp_path / "notes.txt").write_text("tutorial\n")

    assert validate_step(step, "cat notes.txt\ntutorial\n", tmp_path) is True
    assert validate_step(step, "pwd\n", tmp_path) is False
