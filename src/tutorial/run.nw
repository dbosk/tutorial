\section{Checking transcript patterns}

Transcript checks still default to literal matching, but interactive shell
transcripts contain noise that students do not control: carriage returns,
ANSI control sequences, and small whitespace differences from completion or
line editing.  We therefore normalise those details before checking plain
string patterns.  Tutorials that truly need more control can opt into an
explicit regular expression.

<<constants>>=
ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
WHITESPACE_RE = re.compile(r"\s+")
@

<<functions>>=
def normalise_recorded_text(text: str) -> str:
    """Return ``text`` without terminal control noise."""

    text = ANSI_ESCAPE_RE.sub("", text)
    text = text.replace("\r", "\n")
    return text
@

<<functions>>=
def normalise_match_text(text: str) -> str:
    """Return ``text`` with collapsed whitespace for tolerant matching."""

    normalised = normalise_recorded_text(text)
    return WHITESPACE_RE.sub(" ", normalised).strip()
@

<<functions>>=
def transcript_matches_pattern(transcript: str, pattern: TextMatch) -> bool:
    """Return whether one recorded-text check matches ``transcript``."""

    if pattern.mode == "regex":
        return re.search(pattern.pattern, normalise_recorded_text(transcript)) is not None
    if pattern.mode == "contains":
        return normalise_match_text(pattern.pattern) in normalise_match_text(transcript)
    raise ValueError(f"Unsupported text match mode: {pattern.mode!r}")
@

<<functions>>=
def transcript_matches_patterns(
    transcript: str,
    patterns: tuple[TextMatch, ...],
) -> bool:
    """Return whether all required transcript patterns are present."""

    return all(
        transcript_matches_pattern(transcript, pattern)
        for pattern in patterns
    )
@

