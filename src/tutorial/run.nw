\subsection{Selecting which run to use}

Separating this policy into its own method keeps the main run loop about
step execution rather than resume bookkeeping.

<<tutorial runner methods>>=
def select_run(
    self,
    tutorial: Tutorial,
    *,
    restart: bool = False,
) -> tuple[TutorialRun, bool, bool]:
    """Return ``(run, restarted, already_finished)`` for ``tutorial``."""

    latest = self.store.latest_run(tutorial.id)
    if latest is None:
        return self.store.start_run(tutorial), False, False

    progress = self.store.progress_for(tutorial, latest)
    if restart:
        return self.store.start_run(tutorial), True, False

    ensure_run_matches_tutorial(tutorial, latest)

    if progress.finished:
        return latest, False, True

    return latest, False, False
@

