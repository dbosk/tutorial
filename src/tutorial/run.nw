<<functions>>=
def perform_step(
    step: TutorialStep,
    *,
    tutorial_id: str,
    workspace: str | Path,
    shell_runner: Callable[..., ShellResult],
    editor_runner: Callable[..., EditorResult],
    question_runner: Callable[..., ShellResult],
) -> ShellResult | EditorResult:
    """Run one tutorial step with the appropriate interaction backend."""

    kind = step_kind(step)
    if kind == "editor":
        return editor_runner(
            workspace=workspace,
            relative_path=step.edit_file,
        )
    if kind in {"input", "single_select", "multi_select"}:
        return question_runner(step=step)
    return run_step_shell(
        shell_runner,
        workspace=workspace,
        tutorial_id=tutorial_id,
    )
@

