\subsection{Running or resuming a tutorial}

This method owns the high-level control flow.

It starts by resolving the run to use.  If the latest run is unfinished,
we resume it.  If the caller asked for [[restart]], we always create a
new run.  If the tutorial is already finished and [[restart]] is false,
we report that state without opening another shell.

Then, for each remaining step, we optionally notify the caller,
delegate to either the shell or editor backend, validate the recorded
text, and persist the updated run immediately.  Immediate persistence
matters because each step is its own interaction session: if the process
is interrupted between steps, the next invocation should still know where
to resume.

<<tutorial runner methods>>=
def run(
    self,
    tutorial_id: str,
    *,
    restart: bool = False,
    before_step: Callable[[Tutorial, int, TutorialStep, TutorialRun], None]
    | None = None,
) -> RunResult:
    """Run or resume ``tutorial_id``."""

    tutorial = self.catalog.get_tutorial(tutorial_id)
    run, restarted, already_finished = self.select_run(tutorial, restart=restart)
    progress = self.store.progress_for(tutorial, run)
    if already_finished:
        return RunResult(
            tutorial=tutorial,
            run=run,
            progress=progress,
            executed_steps=0,
            restarted=restarted,
            already_finished=True,
        )

    executed_steps = 0
    blocked_step = None
    blocked_transcript = None
    start_index = count_completed_steps(run)

    for step_index in range(start_index, len(tutorial.steps)):
        step = tutorial.steps[step_index]
        if before_step is not None:
            before_step(tutorial, step_index, step, run)

        step_result = perform_step(
            step,
            workspace=run.workspace,
            shell_runner=self.shell_runner,
            editor_runner=self.editor_runner,
        )
        passed = validate_step(
            step,
            recorded_text(step_result),
            run.workspace,
            allow_shell_checks=self.allow_shell_checks,
        )
        transcript = build_step_transcript(
            tutorial_id=tutorial.id,
            step_index=step_index,
            step=step,
            step_result=step_result,
            passed=passed,
        )
        run.transcripts.append(transcript)
        run.updated_at = step_result.ended_at
        self.store.store_run(run)
        progress = self.store.progress_for(tutorial, run)
        executed_steps += 1

        if not passed:
            blocked_step = step
            blocked_transcript = transcript
            break

    return RunResult(
        tutorial=tutorial,
        run=run,
        progress=progress,
        executed_steps=executed_steps,
        restarted=restarted,
        blocked_step=blocked_step,
        blocked_transcript=blocked_transcript,
    )
@

