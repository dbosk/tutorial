def build_step_transcript(
    *,
    tutorial_id: str,
    step_index: int,
    step: TutorialStep,
    step_result: ShellResult | EditorResult,
    passed: bool,
) -> StepTranscript:
    """Convert one step result into a persisted step transcript."""

    if isinstance(step_result, EditorResult):
        return StepTranscript(
            tutorial_id=tutorial_id,
            step_index=step_index,
            title=step.title,
            started_at=step_result.started_at,
            ended_at=step_result.ended_at,
            exit_status=step_result.exit_status,
            transcript=step_result.text,
            passed=passed,
            edited_file=Path(step_result.file_path).name,
        )

    return StepTranscript(
        tutorial_id=tutorial_id,
        step_index=step_index,
        title=step.title,
        started_at=step_result.started_at,
        ended_at=step_result.ended_at,
        exit_status=step_result.exit_status,
        transcript=step_result.transcript,
        passed=passed,
    )
