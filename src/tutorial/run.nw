def review_tutorial(self, tutorial_id: str, run: TutorialRun) -> Tutorial:
    """Return tutorial metadata for review, even without source files."""

    try:
        return self.catalog.get_tutorial(tutorial_id)
    except KeyError:
        step_count = 0
        if run.transcripts:
            step_count = max(item.step_index for item in run.transcripts) + 1
        return Tutorial(
            id=tutorial_id,
            title=run.tutorial_title or tutorial_id,
            summary="Saved tutorial run.",
            steps=tuple(
                TutorialStep(title=f"Step {index + 1}", instructions="")
                for index in range(step_count)
            ),
            source_path=run.tutorial_source_path,
            source_digest=run.tutorial_source_digest,
        )
