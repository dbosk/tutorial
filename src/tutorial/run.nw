\section{Checking transcript patterns}

Transcript checks are intentionally literal.  The goal is not to parse a
shell language but to recognise that the expected command or output
appeared in the recorded session.

<<functions>>=
def transcript_matches_patterns(
    transcript: str,
    patterns: tuple[str, ...],
) -> bool:
    """Return whether all required transcript patterns are present."""

    return all(pattern in transcript for pattern in patterns)
@

<<test functions>>=
def test_transcript_matches_patterns_accepts_empty_requirements():
    assert transcript_matches_patterns("pwd\n", ()) is True


def test_transcript_matches_patterns_requires_all_patterns():
    assert transcript_matches_patterns("pwd\nls\n", ("pwd", "ls")) is True
    assert transcript_matches_patterns("pwd\n", ("pwd", "ls")) is False
@


\section{Checking workspace state}

Some steps are only meaningful if the expected files exist afterwards.
Running a small shell command keeps those checks close to the actual task
the student performed.

<<functions>>=
def check_command_passes(
    command: str | None,
    workspace: str | Path,
    *,
    allow_shell_checks: bool = False,
) -> bool:
    """Return whether ``command`` succeeds in ``workspace``."""

    if command is None:
        return True

    if not allow_shell_checks:
        raise RuntimeError(
            "Tutorial shell checks are disabled. Pass --allow-shell-checks "
            "to trust tutorial-authored validation commands."
        )

    completed = subprocess.run(
        ["/bin/bash", "-lc", command],
        cwd=Path(workspace),
        capture_output=True,
        text=True,
    )
    return completed.returncode == 0
@

<<test functions>>=
def test_check_command_passes_uses_workspace_files(tmp_path):
    (tmp_path / "notes.txt").write_text("tutorial\n")

    assert (
        check_command_passes(
            "grep -q tutorial notes.txt",
            tmp_path,
            allow_shell_checks=True,
        )
        is True
    )
    assert (
        check_command_passes(
            "grep -q missing notes.txt",
            tmp_path,
            allow_shell_checks=True,
        )
        is False
    )
@

