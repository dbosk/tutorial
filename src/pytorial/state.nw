\section{Creating stable timestamps}

We keep timestamps in UTC ISO 8601 format so the files sort well and are
easy to read regardless of the user's local timezone.

<<functions>>=
def utc_now() -> str:
    """Return the current time as an ISO 8601 UTC string."""

    return datetime.now(timezone.utc).isoformat()
@

<<test functions>>=
def test_utc_now_returns_timezone_aware_string():
    assert utc_now().endswith("+00:00")
@


\section{Creating run identifiers}

Run identifiers should sort chronologically but also avoid collisions if
two runs begin within the same second.

<<functions>>=
def build_run_id() -> str:
    """Return a chronologically sortable run identifier."""

    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    return f"{stamp}-{uuid.uuid4().hex[:8]}"
@

<<test functions>>=
def test_build_run_id_contains_timestamp_and_suffix():
    run_id = build_run_id()

    assert "T" in run_id
    assert "-" in run_id
@


