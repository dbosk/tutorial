\section{Selecting the latest transcript per step}

Review wants the current story of a run rather than every failed attempt.
We therefore collapse repeated attempts down to the latest transcript for
each step index.

<<functions>>=
def latest_step_transcripts(run: TutorialRun) -> tuple[StepTranscript, ...]:
    """Return the latest recorded transcript for each attempted step."""

    latest = {}
    for transcript in run.transcripts:
        latest[transcript.step_index] = transcript

    return tuple(latest[index] for index in sorted(latest))
@

<<test functions>>=
def test_latest_step_transcripts_keeps_latest_attempt_only():
    run = TutorialRun(
        tutorial_id="demo",
        run_id="run-1",
        workspace="/tmp/demo",
        started_at="2026-01-01T00:00:00+00:00",
        updated_at="2026-01-01T00:00:03+00:00",
        transcripts=[
            StepTranscript(
                tutorial_id="demo",
                step_index=0,
                title="One",
                started_at="2026-01-01T00:00:00+00:00",
                ended_at="2026-01-01T00:00:01+00:00",
                exit_status=1,
                transcript="bad",
                passed=False,
            ),
            StepTranscript(
                tutorial_id="demo",
                step_index=0,
                title="One",
                started_at="2026-01-01T00:00:01+00:00",
                ended_at="2026-01-01T00:00:02+00:00",
                exit_status=0,
                transcript="good",
                passed=True,
            ),
        ],
    )

    latest = latest_step_transcripts(run)

    assert len(latest) == 1
    assert latest[0].transcript == "good"
@


\section{Counting completed steps}

Tutorials advance in order, so completion is the number of contiguous
steps from the start whose latest attempts passed.

<<functions>>=
def count_completed_steps(run: TutorialRun) -> int:
    """Return the number of consecutively completed steps."""

    latest = {transcript.step_index: transcript for transcript in run.transcripts}
    completed = 0
    while completed in latest and latest[completed].passed:
        completed += 1
    return completed
@

<<test functions>>=
