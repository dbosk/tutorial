        started_at="2026-01-01T00:00:00+00:00",
        updated_at="2026-01-01T00:00:00+00:00",
    )
    second = TutorialRun(
        tutorial_id="shell-basics",
        run_id="run-2",
        workspace="/tmp/two",
        started_at="2026-01-01T00:01:00+00:00",
        updated_at="2026-01-01T00:01:00+00:00",
    )

    store.save_runs("shell-basics", [first, second])

    assert store.latest_run("shell-basics").run_id == "run-2"
