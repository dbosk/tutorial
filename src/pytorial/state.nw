\subsection{Updating one run}

Each completed step appends another transcript to the latest run, so the
store needs an update path that replaces an existing run in-place.

<<state store methods>>=
def store_run(self, run: TutorialRun) -> None:
    """Persist ``run``, replacing the existing record if present."""

    runs = self.load_runs(run.tutorial_id)
    for index, existing in enumerate(runs):
        if existing.run_id == run.run_id:
            runs[index] = run
            break
    else:
        runs.append(run)

    self.save_runs(run.tutorial_id, runs)
@

<<test functions>>=
def test_store_run_replaces_existing_record(tmp_path):
    store = StateStore(tmp_path)
    tutorial = Tutorial(
        id="shell-basics",
        title="Shell Basics",
        summary="A short tutorial.",
        steps=(TutorialStep(title="One", instructions="Do it."),),
    )
    run = store.start_run(tutorial)
    run.transcripts.append(
        StepTranscript(
            tutorial_id="shell-basics",
            step_index=0,
            title="Inspect",
            started_at="2026-01-01T00:00:00+00:00",
            ended_at="2026-01-01T00:00:01+00:00",
            exit_status=0,
            transcript="pwd\n",
            passed=True,
        )
    )

    store.store_run(run)

    assert len(store.latest_run("shell-basics").transcripts) == 1
@


\subsection{Summarising one tutorial's progress}

Progress should count the latest attempt for each step, not every
attempt.  If a student fails step two and then retries it, the tutorial
has still only completed one step until the latest attempt passes.

<<state store methods>>=
def progress_for(
    self,
    tutorial: Tutorial,
    run: TutorialRun | None,
) -> ProgressState:
    """Return a compact progress summary for ``tutorial``."""

    if run is None:
        return ProgressState(
            tutorial_id=tutorial.id,
            total_steps=len(tutorial.steps),
            completed_steps=0,
            finished=False,
        )

    completed_steps = count_completed_steps(run)
    return ProgressState(
        tutorial_id=tutorial.id,
        total_steps=len(tutorial.steps),
        completed_steps=completed_steps,
        finished=completed_steps >= len(tutorial.steps),
        run_id=run.run_id,
        workspace=run.workspace,
        updated_at=run.updated_at,
    )
@

<<test functions>>=
def test_progress_for_counts_latest_passed_steps(tmp_path):
    store = StateStore(tmp_path)
    tutorial = Tutorial(
        id="demo",
        title="Demo",
        summary="A demo tutorial.",
        steps=(
            TutorialStep(title="One", instructions="Do one."),
            TutorialStep(title="Two", instructions="Do two."),
        ),
    )
    run = TutorialRun(
        tutorial_id="demo",
        run_id="run-1",
        workspace="/tmp/demo",
        started_at="2026-01-01T00:00:00+00:00",
        updated_at="2026-01-01T00:00:02+00:00",
        transcripts=[
            StepTranscript(
                tutorial_id="demo",
                step_index=0,
                title="One",
                started_at="2026-01-01T00:00:00+00:00",
                ended_at="2026-01-01T00:00:01+00:00",
                exit_status=0,
                transcript="ok",
                passed=True,
            ),
            StepTranscript(
                tutorial_id="demo",
                step_index=1,
                title="Two",
                started_at="2026-01-01T00:00:01+00:00",
                ended_at="2026-01-01T00:00:02+00:00",
                exit_status=1,
                transcript="not yet",
                passed=False,
            ),
        ],
    )

    progress = store.progress_for(tutorial, run)

    assert progress.completed_steps == 1
    assert progress.finished is False
