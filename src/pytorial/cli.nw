\section{Building the standalone Typer application}

The standalone command adds one concern that embedded hosts should not get:
installing tutorials into the current user's personal catalog.  A small
wrapper around the shared app factory keeps that boundary explicit.

<<functions>>=
def create_standalone_app(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    shell_runner: Callable[..., object] = run_interactive_shell,
    editor_runner: Callable[..., object] = run_editor,
    question_runner: Callable[..., ShellResult] | None = None,
    allow_shell: bool = False,
) -> typer.Typer:
    """Create the standalone tutorial CLI."""

    application = create_app(
        namespace=namespace,
        state_root=state_root,
        tutorial_path_provider=standalone_tutorial_paths,
        shell_runner=shell_runner,
        editor_runner=editor_runner,
        question_runner=question_runner,
        allow_shell=allow_shell,
    )

    @application.command("install")
    def install_command(
        source: str,
        force: Annotated[
            bool,
            typer.Option(
                "--force",
                "-f",
                help="Overwrite an installed tutorial with the same ID.",
            ),
        ] = False,
    ) -> None:
        """Install a tutorial Markdown file or URL for this user."""

        try:
            tutorial_id, target_path = install_tutorial(source, force=force)
        except ValueError as error:
            typer.echo(str(error), err=True)
            raise typer.Exit(code=1)

        typer.echo(f"Installed {tutorial_id} at {target_path}")

    <<register develop command>>

    return application
@

