def run_argparse_command(args: argparse.Namespace) -> int:
    """Dispatch a parsed argparse tutorial command."""

    handler = getattr(args, "tutorial_handler", None)
    if handler is None:
        raise ValueError("No tutorial handler found on parsed arguments.")
    return handler(args)
