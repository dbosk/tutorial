def argparse_run_command(
    args: argparse.Namespace,
    *,
    namespace: str,
    state_root: str | Path | None,
    tutorial_paths: tuple[str | Path, ...],
    shell_runner: Callable[..., object],
    editor_runner: Callable[..., object],
    question_runner: Callable[..., ShellResult] | None,
    allow_shell: bool,
) -> int:
    """Implement the argparse ``run`` subcommand."""

    try:
        console = Console()

        def prompt_for_input(prompt: str) -> str:
            return input(f"{prompt}: ")

        command_question_runner = make_question_step_runner(
            console=console,
            prompt_for_input=prompt_for_input,
            question_runner=question_runner,
        )

        tutorial_runner = build_command_runner(
            namespace=namespace,
            state_root=state_root,
            configured_tutorial_paths=tutorial_paths,
            command_tutorial_paths=tuple(args.tutorial_path),
            shell_runner=shell_runner,
            editor_runner=editor_runner,
            question_runner=command_question_runner,
            allow_shell=allow_shell,
            command_allow_shell=args.allow_shell,
            require_paths=True,
        )

        def before_step(tutorial, step_index, step, run) -> None:
            render_step_for_run(
                console=console,
                tutorial=tutorial,
                step_index=step_index,
                step=step,
                run=run,
                prompt_for_editor_start=prompt_for_input,
            )

        result = run_tutorial_with_menu(
            tutorial_runner,
            args.tutorial_id,
            restart=args.restart,
            before_step=before_step,
            console=console,
            prompt_for_input=prompt_for_input,
        )
    except (KeyError, RuntimeError, ValueError) as error:
        print(error)
        return 1

    if result.blocked_step is not None:
        return 1

    try:
        emit_run_summary(result)
    except typer.Exit as error:
        return error.exit_code
    return 0
