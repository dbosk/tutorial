\section{Formatting step prompts}

Each step opens a fresh interaction, so the CLI must print the
instructions before that interaction starts.  We author that
student-facing text as Markdown and render it with Rich [[Markdown]] so
paragraphs and inline commands read cleanly in an ordinary terminal.

A little vertical space around the body matters too.  Without it, the
workspace line, the instructions, and the interaction reminder blur
together into one dense block of text.

The reminder itself depends on the step mode.  Shell steps ask the
student to exit the shell, editor steps ask them to save and quit the
editor, and question steps tell them how to answer directly in the CLI.

<<functions>>=
def question_step_prompt(step) -> str:
    """Return the prompt string used to capture one question answer."""

    kind = step_kind(step)
    if kind == "input":
        return "Answer"
    if kind == "single_select":
        return "Choose one option"
    if kind == "multi_select":
        return "Choose all that apply"
    raise ValueError(f"Step {step.title!r} is not a question step.")
@

<<functions>>=
def render_question_options(
    console: Console,
    options: tuple[str, ...],
) -> None:
    """Render the authored options for a select-style question step."""

    if not options:
        return

    console.print("Options:", style="bold")
    for index, option in enumerate(options, start=1):
        console.print(f"  {index}. {option}")
    console.print()
@

<<functions>>=
def render_step_prompt(
    console: Console,
    tutorial_title: str,
    step_number: int,
    total_steps: int,
    step_title: str,
    instructions: str,
    workspace: str,
    *,
    kind: str | None = None,
    options: tuple[str, ...] = (),
    edit_file: str | None = None,
) -> None:
    """Render the prompt shown before one interactive step."""

    if kind is None:
        kind = "editor" if edit_file is not None else "shell"

    console.print()
    console.print(tutorial_title, style="bold")
    console.print(
        f"Step {step_number}/{total_steps}: {step_title}",
        style="bold",
    )
    console.print(f"Workspace: {workspace}", style="dim")
    if edit_file is not None:
        console.print(f"File: {edit_file}", style="dim")
    console.print()
    console.print(Markdown(instructions))
    console.print()
    if kind == "shell":
        console.print(
            "Exit the shell when you want the tutorial to validate the step.",
            style="dim",
        )
    elif kind == "editor":
        console.print(
            "Save the file and quit the editor when you want the tutorial "
            "to validate the step.",
            style="dim",
        )
    elif kind == "input":
        console.print(
            "Type your answer on one line when you are ready.",
            style="dim",
        )
    elif kind == "single_select":
        render_question_options(console, options)
        console.print(
            "Answer with an option number or the full option text.",
            style="dim",
        )
    elif kind == "multi_select":
        render_question_options(console, options)
        console.print(
            "Answer with option numbers or texts separated by commas.",
            style="dim",
        )
    else:
        raise ValueError(f"Unsupported step kind: {kind!r}")
    console.print()
@

