\section{Installing tutorials into the user catalog}

Standalone installation writes each tutorial to a predictable filename based
on its tutorial ID.  That gives one stable location per installed tutorial
and makes duplicate detection a simple overwrite policy instead of a search
through arbitrary filenames.

<<functions>>=
def installed_tutorial_file(tutorial_id: str) -> Path:
    """Return the canonical installed path for ``tutorial_id``."""

    return user_tutorial_dir() / f"{tutorial_id}.md"
@

<<functions>>=
def install_tutorial(source: str, *, force: bool = False) -> tuple[str, Path]:
    """Install one tutorial from a file path or URL."""

    source_name, text = read_tutorial_source(source)
    tutorial = parse_tutorial_text(text, source_path=source_name)
    if tutorial.id in tuple(
        item.id
        for item in TutorialCatalog(builtin_tutorial_paths()).get_tutorials()
    ):
        raise ValueError(
            f"Tutorial {tutorial.id!r} is built in and cannot be installed."
        )
    target_path = installed_tutorial_file(tutorial.id)

    if target_path.exists() and target_path.is_dir():
        raise ValueError(f"Installed tutorial path {target_path} is a directory.")
    if target_path.exists() and not force:
        raise ValueError(
            f"Tutorial {tutorial.id!r} is already installed at {target_path}. "
            "Use --force to overwrite."
        )

    target_path.parent.mkdir(parents=True, exist_ok=True)
    try:
        target_path.write_text(text)
    except OSError as error:
        raise ValueError(
            f"Could not install tutorial at {target_path}: {error}"
        ) from error
    return tutorial.id, target_path
@

