    assert normalise_editor_start_choice("") is True
    assert normalise_editor_start_choice("yes") is True
    assert normalise_editor_start_choice("Y") is True
    assert normalise_editor_start_choice("no") is False
    assert normalise_editor_start_choice("later") is None
@

<<functions>>=
def prompt_to_start_editor(
    console: Console,
    prompt_for_input: Callable[[str], str],
) -> None:
    """Wait for confirmation before opening a full-screen editor."""

    prompt = "Start the editor? [Y/n]"
    while True:
        confirmation = normalise_editor_start_choice(prompt_for_input(prompt))
        if confirmation is True:
            return
        if confirmation is False:
            console.print(
                "Answer yes when you are ready to open the editor.",
                style="dim",
            )
            continue
        console.print("Answer yes or no.", style="dim")
@


\section{Normalising question answers}

Question steps still persist ordinary transcript text, so the CLI only has
to turn user-facing conveniences such as option numbers into a stable
recorded form before handing the result to the runner.

<<functions>>=
def resolve_question_choice(choice: str, options: tuple[str, ...]) -> str | None:
    """Return the authored option addressed by ``choice``."""

    token = choice.strip()
    if not token:
        return None
    if token.isdigit():
        index = int(token) - 1
        if 0 <= index < len(options):
            return options[index]
        return None
    for option in options:
        if token == option:
            return option
    return None
@

<<functions>>=
def normalise_question_answer(step, answer: str) -> str | None:
    """Return a stable recorded answer for one question step."""

    kind = step_kind(step)
    if kind == "input":
        return answer.strip()
    if kind == "single_select":
        return resolve_question_choice(answer, step.options)
    if kind == "multi_select":
        selections = []
        seen = set()
        for token in answer.split(","):
            choice = resolve_question_choice(token, step.options)
            if choice is None:
                return None
            if choice in seen:
                continue
            seen.add(choice)
            selections.append(choice)
        if not selections:
            return None
        return "\n".join(
            option for option in step.options if option in seen
        )
    raise ValueError(f"Step {step.title!r} is not a question step.")
@

<<functions>>=
def run_question_step(
    step,
    *,
    prompt_for_input: Callable[[str], str],
    console: Console,
) -> ShellResult:
    """Prompt once for a question step and return a recorded result."""

    started_at = utc_now()
    while True:
        raw_answer = prompt_for_input(question_step_prompt(step))
        answer = normalise_question_answer(step, raw_answer)
        if answer is not None:
            return ShellResult(
                started_at=started_at,
                ended_at=utc_now(),
                exit_status=0,
                transcript=answer,
            )
        console.print("Answer using the listed options.", style="dim")
@

The run flows differ in how they ask for input, but not in how they present a
step or how they turn a question step into a [[ShellResult]].  These helpers
keep that interaction policy shared while leaving each front end free to supply
its own prompting primitive.  That gives the reader one place to understand the
interactive contract before contrasting Typer and argparse.

<<functions>>=
def make_question_step_runner(
    *,
    console: Console,
    prompt_for_input: Callable[[str], str],
    question_runner: Callable[..., ShellResult] | None = None,
) -> Callable[..., ShellResult]:
    """Return the question runner for one command invocation."""

    def command_question_runner(*, step):
        if question_runner is not None:
            return question_runner(step=step)
        return run_question_step(
            step,
            prompt_for_input=prompt_for_input,
            console=console,
        )

    return command_question_runner
@

<<functions>>=
def render_step_for_run(
    *,
    console: Console,
    tutorial,
    step_index: int,
    step,
    run,
    prompt_for_editor_start: Callable[[str], str],
) -> None:
    """Render one step prompt during an interactive run."""

    render_step_prompt(
        console,
        tutorial.title,
        step_index + 1,
        len(tutorial.steps),
        step.title,
        step.instructions,
        run.workspace,
        kind=step_kind(step),
        options=step.options,
        edit_file=step.edit_file,
    )
    if step.edit_file is not None:
        prompt_to_start_editor(console, prompt_for_editor_start)
