<<functions>>=
def require_tutorial_paths(
    tutorial_paths: tuple[str | Path, ...],
) -> tuple[str | Path, ...]:
    """Require an explicit tutorial path for commands that load tutorials."""

    if tutorial_paths:
        return tutorial_paths
    raise RuntimeError("No tutorial paths configured. Pass --tutorial-path.")
@

Some commands add temporary tutorial paths, question backends, or validation
flags, but the rule for turning those into one [[TutorialRunner]] should stay
the same across Typer and argparse.  The shared helper below makes that
command-scoped runner wiring explicit in one place, so later front-end
sections can focus on prompts and exit conventions instead of rebuilding the
same path logic.

<<functions>>=
def build_command_runner(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    configured_tutorial_paths: tuple[str | Path, ...] = (),
    command_tutorial_paths: tuple[str | Path, ...] = (),
    shell_runner: Callable[..., object] = run_interactive_shell,
    editor_runner: Callable[..., object] = run_editor,
    question_runner: Callable[..., ShellResult] | None = None,
    allow_shell: bool = False,
    command_allow_shell: bool = False,
    require_paths: bool = False,
) -> TutorialRunner:
    """Build a runner for one concrete command invocation."""

    tutorial_paths = effective_tutorial_paths(
        configured_tutorial_paths,
        command_tutorial_paths,
    )
    if require_paths:
        tutorial_paths = require_tutorial_paths(tutorial_paths)
    return build_runner(
        namespace=namespace,
        state_root=state_root,
        tutorial_paths=tutorial_paths,
        shell_runner=shell_runner,
        editor_runner=editor_runner,
        question_runner=question_runner,
        allow_shell=allow_shell or command_allow_shell,
    )
@

