\section{Reading tutorial sources for installation}

Installation accepts either a local Markdown file or a remote Markdown URL.
Both sources should go through the same validation path, so the only job
here is to fetch text and reject obviously wrong inputs early.

<<functions>>=
def is_tutorial_url(source: str) -> bool:
    """Return whether ``source`` looks like an HTTP(S) tutorial URL."""

    parsed = urllib.parse.urlparse(source)
    return parsed.scheme in {"http", "https"} and bool(parsed.netloc)
@

<<functions>>=
def read_tutorial_source(source: str) -> tuple[str, str]:
    """Return ``(source_name, text)`` for one installable tutorial."""

    if is_tutorial_url(source):
        parsed = urllib.parse.urlparse(source)
        if Path(parsed.path).suffix.lower() != ".md":
            raise ValueError(
                f"Tutorial URL {source} must point to a .md file."
            )
        try:
            with urllib.request.urlopen(source, timeout=30) as response:
                encoding = response.headers.get_content_charset() or "utf-8"
                return source, response.read().decode(encoding)
        except (OSError, urllib.error.URLError, UnicodeDecodeError) as error:
            raise ValueError(
                f"Could not read tutorial URL {source}: {error}"
            ) from error

    path = Path(source)
    if not path.exists():
        raise ValueError(f"Tutorial path {path} does not exist.")
    if not path.is_file():
        raise ValueError(f"Tutorial path {path} must be a file.")
    if path.suffix.lower() != ".md":
        raise ValueError(f"Tutorial file {path} must use the .md extension.")

    resolved_path = path.resolve()
    try:
        return str(resolved_path), resolved_path.read_text()
    except OSError as error:
        raise ValueError(
            f"Could not read tutorial file {path}: {error}"
        ) from error
@

