\section{Locating saved state without side effects}

Shell completion should not create directories just because the user hit
tab.  The normal [[StateStore]] constructor eagerly creates its storage
tree, so completion uses a small read-only helper that mirrors the same
root-selection logic.

<<functions>>=
def state_root_path(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
) -> Path:
    """Return the state root for one CLI host without creating it."""

    if state_root is not None:
        return Path(state_root)
    return (
        platformdirs.user_state_path(
            "tutorial",
            appauthor=False,
            ensure_exists=False,
        )
        / namespace
    )
@


\section{Reading saved tutorial state}

Review completions should reflect what is actually saved, not only what
is present in the current catalog.  We therefore read tutorial and run
identifiers straight from the JSON files.

<<functions>>=
def saved_tutorial_ids(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
) -> tuple[str, ...]:
    """Return tutorial IDs that already have saved runs."""

    runs_dir = state_root_path(
        namespace=namespace,
        state_root=state_root,
    ) / "runs"
    if not runs_dir.exists():
        return ()
    return tuple(
        path.stem
        for path in sorted(runs_dir.glob("*.json"))
        if path.is_file()
    )
@

<<functions>>=
def saved_run_ids(
    tutorial_id: str,
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
) -> tuple[str, ...]:
    """Return saved run IDs for ``tutorial_id``."""

    path = (
        state_root_path(
            namespace=namespace,
            state_root=state_root,
        )
        / "runs"
        / f"{tutorial_id}.json"
    )
    if not path.exists():
        return ()

    try:
        payload = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return ()

    run_ids = []
    for item in payload.get("runs", []):
        if not isinstance(item, dict):
            continue
        run_id = item.get("run_id")
        if isinstance(run_id, str):
            run_ids.append(run_id)
    return tuple(run_ids)
@


\section{Completing tutorial and run identifiers}

The run command should complete the tutorials that are currently loadable.
Review is different: it should complete only saved tutorial and run
identifiers, because those are the values the command can actually open.

<<functions>>=
def matching_completion_values(
    values: tuple[str, ...],
    incomplete: str,
) -> list[str]:
    """Return unique completion candidates that match ``incomplete``."""

    matches = []
    seen = set()
    for value in values:
        if not value.startswith(incomplete) or value in seen:
            continue
        seen.add(value)
        matches.append(value)
    return matches
@

<<functions>>=
def tutorial_ids_from_paths(
    tutorial_paths: tuple[str | Path, ...],
) -> tuple[str, ...]:
    """Return tutorial IDs loadable from ``tutorial_paths``."""

    if not tutorial_paths:
        return ()

    try:
        return tuple(
            tutorial.id
            for tutorial in TutorialCatalog(tutorial_paths).get_tutorials()
        )
    except ValueError:
        return ()
@

<<functions>>=
def suggest_run_tutorial_ids(
    configured_paths: tuple[str | Path, ...],
    command_paths: tuple[str | Path, ...],
    incomplete: str,
) -> list[str]:
    """Return tutorial ID completions for the run command."""

    return matching_completion_values(
        tutorial_ids_from_paths(
            effective_tutorial_paths(configured_paths, command_paths)
        ),
        incomplete,
    )
@

<<functions>>=
def suggest_review_tutorial_ids(
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    incomplete: str,
) -> list[str]:
    """Return tutorial ID completions for the review command."""

    return matching_completion_values(
        saved_tutorial_ids(
            namespace=namespace,
            state_root=state_root,
        ),
        incomplete,
    )
@

<<functions>>=
def suggest_review_run_ids(
    tutorial_id: str,
    *,
    namespace: str = "tutorial",
    state_root: str | Path | None = None,
    incomplete: str,
) -> list[str]:
    """Return run ID completions for one saved tutorial."""

    return matching_completion_values(
        saved_run_ids(
            tutorial_id,
            namespace=namespace,
            state_root=state_root,
        ),
        incomplete,
    )
@

