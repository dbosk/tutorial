\subsection{Finding the run to review}

Most review requests target the latest run, but a specific run ID should
still be retrievable when the host application wants that level of
control.

<<tutorial runner methods>>=
def get_run(
    self,
    tutorial_id: str,
    *,
    run_id: str | None = None,
) -> TutorialRun:
    """Return the latest or requested run for ``tutorial_id``."""

    if run_id is None:
        run = self.store.latest_run(tutorial_id)
        if run is None:
            raise KeyError(f"No saved run for tutorial {tutorial_id!r}.")
        return run

    for run in self.store.load_runs(tutorial_id):
        if run.run_id == run_id:
            return run

    raise KeyError(
        f"No saved run {run_id!r} for tutorial {tutorial_id!r}."
    )
