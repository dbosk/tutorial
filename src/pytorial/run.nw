def test_runner_completes_shell_basics_with_mixed_backends(tmp_path):
    tutorial_path = write_demo_tutorial(tmp_path)
    store = StateStore(tmp_path / "state")
    commands = iter(
        [
            "pwd\nls\n",
            "touch notes.txt\n",
            "cat notes.txt\n",
        ]
    )
    answers = iter(["pwd", "ls", "pwd\nls"])

    def scripted_runner(*, workspace, prompt_name="tutorial"):
        return run_scripted_shell(
            next(commands),
            workspace=workspace,
            prompt_name=prompt_name,
        )

    def fake_editor_runner(*, workspace, relative_path, initial_text=None):
        file_path = Path(workspace) / relative_path
        file_path.write_text("tutorial\n")
        return EditorResult(
            started_at="2026-01-01T00:00:01+00:00",
            ended_at="2026-01-01T00:00:02+00:00",
            exit_status=0,
            file_path=str(file_path),
            text="tutorial\n",
        )

    def fake_question_runner(*, step):
        return ShellResult(
            started_at="2026-01-01T00:00:02+00:00",
            ended_at="2026-01-01T00:00:03+00:00",
            exit_status=0,
            transcript=next(answers),
        )

    runner = TutorialRunner(
        store,
        TutorialCatalog((tutorial_path,)),
        shell_runner=scripted_runner,
        editor_runner=fake_editor_runner,
        question_runner=fake_question_runner,
        allow_shell_checks=True,
